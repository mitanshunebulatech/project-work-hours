# Copy this file to .env and fill in real values before running.
# Never commit the actual .env file — it is already gitignored.

APP_NAME=WorkHours Enterprise
APP_ENV=development
DEBUG=true

# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://workhours:password@localhost:5432/workhours_db
DB_POOL_MIN=5
DB_POOL_MAX=20

# Generate a strong random key, e.g.: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

CORS_ORIGINS=["http://localhost:8000","http://localhost:8080"]

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

LOGIN_RATE_LIMIT=10/minute

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY_IN_PRODUCTION

# Leave request attachments
UPLOAD_DIR=uploads/leave_attachments
MAX_ATTACHMENT_SIZE_MB=10
ALLOWED_ATTACHMENT_EXTENSIONS=[".pdf",".jpg",".jpeg",".png",".docx"]

# Identity documents (Aadhaar/PAN/Passport/Other) — encrypted at rest
IDENTITY_DOCS_DIR=uploads/identity_documents
MAX_IDENTITY_DOC_SIZE_MB=10
ALLOWED_IDENTITY_DOC_EXTENSIONS=[".pdf",".jpg",".jpeg",".png"]

# Profile pictures — not encrypted
PROFILE_PICTURES_DIR=uploads/profile_pictures
MAX_PROFILE_PICTURE_SIZE_MB=5
ALLOWED_PROFILE_PICTURE_EXTENSIONS=[".jpg",".jpeg",".png"]

# Email (onboarding welcome message). Works with any SMTP server — Gmail
# (use an App Password, not your real password), a self-hosted Postfix box,
# or a local dev catcher like Mailhog/aiosmtpd. Leave SMTP_HOST empty to
# disable email sending (onboarding still works, it just skips the email).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=noreply@workhours.local
SMTP_FROM_NAME=WorkHours Enterprise
